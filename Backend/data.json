ription": "An AC mechanic (or technician) installs, maintains, and repairs residential, commercial, or industrial HVAC systems. Key responsibilities include diagnosing electrical/mechanical faults, replacing broken components like compressors and motors, charging systems with refrigerant, and performing routine maintenance to ensure optimal performance. They ensure safety compliance, clean coils, and often work on-call, requiring technical knowledge, hand-tool proficiency, and strong customer service skills."}}, {"model": "Api.provider", "pk": 3, "fields": {"image": "localservice.jpg", "provider": 7, "service": 2, "approved": true, "location": null, "salary": "Based on Work"}}, {"model": "Api.provider", "pk": 10, "fields": {"image": "localservice.jpg", "provider": 24, "service": 2, "approved": true, "location": "Thisayanvilai", "salary": "Based on Work"}}, {"model": "Api.provider", "pk": 11, "fields": {"image": "localservice.jpg", "provider": 26, "service": 4, "approved": true, "location": "Tirunelveli", "salary": "1000 per day"}}, {"model": "Api.provider", "pk": 12, "fields": {"image": "localservice.jpg", "provider": 27, "service": 5, "approved": false, "location": "Tirunelveli", "salary": "Based on Work"}}, {"model": "Api.provider", "pk": 13, "fields": {"image": "localservice.jpg", "provider": 28, "service": 3, "approved": false, "location": "Thoothukudi", "salary": "Based on Work"}}, {"model": "Api.provider", "pk": 14, "fields": {"image": "localservice.jpg", "provider": 29, "service": 5, "approved": true, "location": "Tenkasi", "salary": "Based on Work"}}, {"model": "Api.provider", "pk": 15, "fields": {"image": "providers/plumber.jpg", "provider": 30, "service": 3, "approved": true, "location": "Thisayanvilai", "salary": "Based on Work"}}, {"model": "Api.booking", "pk": 1, "fields": {"service_provider": 3, "customer": 9, "date": "2026-02-13", "time": "11:00:00", "status": "pending", "created_on": "2026-02-13T15:56:56.734Z"}}, {"model": "Api.booking", "pk": 2, "fi